    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug",
            "program": "${workspaceFolder}/target/debug/market_int",
            "args": [
                "perform-all",
                "data/symbols.csv"
            ],
            "env": {
                "RUST_LOG": "debug",
            },
            "cwd": "${workspaceFolder}",
            "sourceLanguages": ["rust"],
            "initCommands": [
                "command script import \"/Users/yinlootan/.rustup/toolchains/stable-aarch64-apple-darwin/lib/rustlib/etc/lldb_lookup.py\"",
                "command source /Users/yinlootan/.rustup/toolchains/stable-aarch64-apple-darwin/lib/rustlib/etc/lldb_commands"
            ]
        }
    ]
}
